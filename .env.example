# ==========================================
# Freecart 환경 변수 템플릿 (Vite SPA)
# ==========================================
# 이 파일을 .env로 복사한 후 Supabase 정보를 입력하세요:
#   cp .env.example .env
#
# ※ Supabase 접속 정보만 여기에 설정합니다.
# ※ 그 외 모든 설정(사이트명, 배송비, PG키, 소셜로그인 등)은
#   관리자 페이지 > 설정 에서 관리됩니다. (DB settings 테이블)
# ==========================================

# ------------------------------------------
# 1. Supabase 프로젝트 정보 (필수)
# ------------------------------------------
# Supabase 대시보드 → Project Settings → API 에서 확인
# https://supabase.com/dashboard/project/<your-project-id>/settings/api
#
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi....

# ------------------------------------------
# 2. 최초 설치 순서
# ------------------------------------------
#
# [1단계] 의존성 설치
#   npm install
#
# [2단계] DB 초기화 (Supabase SQL 에디터에서 실행)
#   scripts/db-schema-full.sql 전체 내용 실행
#   https://supabase.com/dashboard/project/<your-project-id>/sql/new
#
# [3단계] Supabase CLI 로그인
#   npx supabase login
#   → 브라우저가 열리면 Supabase 계정으로 로그인
#
# [4단계] Edge Functions 배포 (서버 코드 업로드)
#   npm run functions:deploy
#   → .env의 VITE_SUPABASE_URL에서 project-ref를 자동으로 읽어 배포
#   → 개별 배포: node scripts/deploy-functions.js <함수명>
#
# [5단계] 개발 서버 시작
#   npm run dev
#
# ------------------------------------------
# 3. Edge Functions 목록 (functions:deploy 대상)
# ------------------------------------------
#   verify-payment     - 토스페이먼츠 결제 검증
#   send-email         - 이메일 발송
#   send-webhook       - 아웃바운드 웹훅 발송
#   test-integration   - 외부 연동 연결 테스트
#   gf-shipping-print  - 굿스플로 송장 발급/조회
#   gf-webhook-receiver - 굿스플로 배송 상태 웹훅 수신
#   issue-temp-passwords - 임시 비밀번호 발급
#
# Edge Function 코드 수정 후 재배포:
#   npm run functions:deploy                       # 전체
#   node scripts/deploy-functions.js gf-shipping-print  # 단일
#
# ------------------------------------------
# 4. 자주 쓰는 명령어
# ------------------------------------------
#   npm run dev              - 개발 서버 (http://localhost:4000)
#   npm run build            - 프로덕션 빌드
#   npm run functions:deploy - Edge Functions 전체 배포
#   npx supabase login       - Supabase CLI 로그인
