# ==========================================
# Freecart 환경 변수 템플릿 (Vite SPA)
# ==========================================
# 이 파일을 .env로 복사한 후 값을 입력하세요:
#   cp .env.example .env
# ==========================================

# ==========================================
# Supabase (필수)
# ==========================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# 사이트 정보
# ==========================================
VITE_SITE_URL=http://localhost:5173
VITE_SITE_NAME=Freecart

# ==========================================
# PG 결제 - 토스페이먼츠 (선택)
# ==========================================
VITE_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx

# ==========================================
# 테마/스킨 스토어 (freecart-web 연동)
# ==========================================
VITE_STORE_API_URL=http://localhost:3001

# ==========================================
# Cloudflare (배포 시)
# ==========================================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_PROJECT_NAME=freecart
