# ==========================================
# Freecart 환경 변수 템플릿
# ==========================================
#
# 이 파일을 .env로 복사한 후 값을 입력하세요:
#   cp .env.example .env
#
# ==========================================

# ==========================================
# 환경 (development | production)
# ==========================================
NODE_ENV=development

# ==========================================
# 사이트 정보
# ==========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Freecart

# ==========================================
# Supabase (필수)
# ==========================================
# Supabase Dashboard → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버 전용 (절대 클라이언트에 노출 금지!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# 데이터베이스 (선택 사항)
# ==========================================
# Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ==========================================
# 암호화 키 (필수)
# ==========================================
# 생성 방법: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==========================================
# GitHub 자동 배포 (선택)
# ==========================================
# GitHub Personal Access Token (repo 권한 필요)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=username/my-freecart-site
GITHUB_BRANCH=main

# ==========================================
# Cloudflare Pages (선택)
# ==========================================
# Cloudflare Dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_PROJECT_NAME=my-freecart-site

# ==========================================
# PG 결제 - 토스페이먼츠 (선택)
# ==========================================
# 테스트 환경
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxx
TOSS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# 프로덕션 환경 (주석 해제하여 사용)
# TOSS_CLIENT_KEY=live_ck_xxxxxxxxxxxxxxxxxxxx
# TOSS_SECRET_KEY=live_sk_xxxxxxxxxxxxxxxxxxxx
# TOSS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ==========================================
# PG 결제 - 기타 (선택)
# ==========================================
# KG이니시스
# INICIS_MID=your-merchant-id
# INICIS_SIGNKEY=your-sign-key

# NHN KCP
# KCP_SITE_CD=your-site-code
# KCP_SITE_KEY=your-site-key

# 나이스페이
# NICEPAY_MID=your-merchant-id
# NICEPAY_MERCHANT_KEY=your-merchant-key

# ==========================================
# 알림 - 카카오 알림톡 (선택)
# ==========================================
KAKAO_API_KEY=your-kakao-api-key
KAKAO_SENDER_KEY=your-sender-key

# ==========================================
# 알림 - SMS (선택)
# ==========================================
# NHN Cloud SMS 예시
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_NUMBER=02-1234-5678

# ==========================================
# 알림 - 이메일 (선택)
# ==========================================
# SMTP 설정
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@freecart.kr
SMTP_PASS=your-smtp-password

# 발신자 정보
EMAIL_FROM_NAME=Freecart
EMAIL_FROM_ADDRESS=noreply@freecart.kr

# ==========================================
# 외부 연동 - 도매꾹 (선택)
# ==========================================
DOMEGOOK_API_KEY=your-domegook-api-key
DOMEGOOK_API_SECRET=your-domegook-api-secret

# ==========================================
# 외부 연동 - 네이버 쇼핑 (선택)
# ==========================================
NAVER_SHOPPING_CLIENT_ID=your-naver-client-id
NAVER_SHOPPING_CLIENT_SECRET=your-naver-client-secret

# ==========================================
# 외부 연동 - 카페24 (선택)
# ==========================================
CAFE24_API_KEY=your-cafe24-api-key
CAFE24_API_SECRET=your-cafe24-api-secret
CAFE24_MALL_ID=your-mall-id

# ==========================================
# 로깅 및 모니터링 (선택)
# ==========================================
# Sentry
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==========================================
# Redis (선택 - 캐싱/세션용)
# ==========================================
# REDIS_URL=redis://localhost:6379

# ==========================================
# 기타
# ==========================================
# JWT Secret (자동 생성됨)
# JWT_SECRET=your-jwt-secret

# 파일 업로드 최대 크기 (MB)
MAX_FILE_SIZE=5

# 세션 타임아웃 (초)
SESSION_TIMEOUT=3600

# Rate Limiting (분당 요청 수)
RATE_LIMIT_PER_MINUTE=100
